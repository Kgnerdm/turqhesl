# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/turqheal

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# JWT (optional overrides)
# ACCESS_TOKEN_LIFETIME_MINUTES=15
# REFRESH_TOKEN_LIFETIME_DAYS=7

# Cloudinary (media storage)
# Get these from https://cloudinary.com/console after signup (no credit card required)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Celery (async task queue)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=django-db

# Email — defaults to console output. For real delivery (prod) set:
#   EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
#   EMAIL_HOST=smtp.gmail.com         (or Brevo: smtp-relay.brevo.com)
#   EMAIL_HOST_USER=...               (sender address / SMTP username)
#   EMAIL_HOST_PASSWORD=...           (Gmail app password / Brevo SMTP key)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=TurqHeal <noreply@turqheal.com>

# Public URL for links inside emails
FRONTEND_URL=http://localhost:3001

# Payments — 'mock' (default, sandbox) or 'stripe' (production)
PAYMENT_PROVIDER=mock
# Required only when PAYMENT_PROVIDER=stripe:
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
