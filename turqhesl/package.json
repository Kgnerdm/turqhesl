{
  "name": "turqhesl",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces",
    "dev:admin": "npm run dev --workspace=@turqhesl/admin",
    "dev:customer": "npm run dev --workspace=@turqhesl/customer",
    "build": "npm run build --workspaces",
    "build:admin": "npm run build --workspace=@turqhesl/admin",
    "build:customer": "npm run build --workspace=@turqhesl/customer",
    "start:admin": "npm run start --workspace=@turqhesl/admin",
    "start:customer": "npm run start --workspace=@turqhesl/customer",
    "lint": "npm run lint --workspaces"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.0.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
